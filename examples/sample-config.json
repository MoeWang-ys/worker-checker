{
  "_说明": "这是一个示例配置，演示 Orchestrator 的完整工作流。实际使用时由 Orchestrator 根据用户需求生成。",

  "task": {
    "description": "写一个 Python 函数 validate_email(email: str) -> dict，校验邮箱地址是否合法。返回格式：{\"valid\": true/false, \"reason\": \"说明\", \"normalized\": \"规范化后的邮箱\"}。校验规则：1) 包含且仅包含一个 @ 2) @ 前后都有非空字符 3) 域名部分至少有一个点 4) 总长度不超过 254 字符 5) 清理首尾空格",
    "output_format": {
      "description": "返回一个 JSON 对象",
      "schema": {
        "type": "object",
        "required": ["valid", "reason", "normalized"],
        "properties": {
          "valid": {"type": "boolean"},
          "reason": {"type": "string"},
          "normalized": {"type": "string"}
        }
      },
      "example": {
        "valid": true,
        "reason": "格式合法",
        "normalized": "user@example.com"
      }
    },
    "context": {
      "constraints": [
        "使用 Python 3.12 标准库，不依赖第三方包",
        "函数名必须为 validate_email",
        "不使用正则表达式（用字符串方法实现）"
      ]
    }
  },

  "checklist": {
    "items": [
      {
        "id": "correctness",
        "dimension": "正确性",
        "check": "函数是否正确实现了所有 5 条校验规则。测试用例：空字符串→false, 'a@b.c'→true, 'a@@b.c'→false, '@b.c'→false, 'a@b'→false, 'a@b.c'带空格→清理后返回true",
        "scoring": {"type": "score", "max": 10}
      },
      {
        "id": "code_quality",
        "dimension": "代码质量",
        "check": "函数签名是否正确（参数名 email，返回 dict），命名清晰，逻辑可读",
        "scoring": {"type": "score", "max": 5}
      },
      {
        "id": "constraints",
        "dimension": "约束遵守",
        "check": "是否使用了正则表达式（违规），是否使用了第三方包（违规），函数名是否为 validate_email",
        "scoring": {"type": "pass_fail"}
      },
      {
        "id": "robustness",
        "dimension": "健壮性",
        "check": "对 None、非字符串类型输入是否有合理处理",
        "scoring": {"type": "score", "max": 5}
      }
    ]
  },

  "criteria": {
    "pass_conditions": [
      {
        "id": "correctness_score",
        "type": "threshold",
        "source": "results[0].score",
        "operator": ">=",
        "value": 8,
        "description": "正确性得分 >= 8/10"
      },
      {
        "id": "all_items_pass",
        "type": "all_items_pass",
        "source": "results",
        "operator": "==",
        "value": true,
        "description": "所有检查项的 pass 字段都为 true"
      },
      {
        "id": "overall_pass_rate",
        "type": "threshold",
        "source": "overall.pass_rate",
        "operator": ">=",
        "value": 0.8,
        "description": "总体通过率 >= 80%"
      }
    ],
    "logic": "all",
    "hard_blocks": ["all_items_pass"],
    "max_rounds": 3
  },

  "options": {
    "production_model": "haiku",
    "check_model": "sonnet",
    "max_rounds": 3,
    "output_dir": "run_output",
    "bare": true,
    "worker_timeout": 600
  }
}
